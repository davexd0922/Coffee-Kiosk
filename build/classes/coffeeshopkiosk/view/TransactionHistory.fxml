<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="coffeeshopkiosk.controller.TransactionHistoryController">
    <padding>
        <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
    </padding>
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Label styleClass="screen-title" text="Transaction History" />
            <Button onAction="#voidSelectedTransaction" styleClass="danger-button" text="Void Selected" />
            <Button onAction="#refresh" text="Refresh" />
        </HBox>
    </top>
    <center>
        <VBox>
            <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" prefWidth="80.0" text="ID" />
                    <TableColumn fx:id="dateColumn" prefWidth="170.0" text="Date" />
                    <TableColumn fx:id="cashierColumn" prefWidth="160.0" text="Cashier" />
                    <TableColumn fx:id="subtotalColumn" prefWidth="110.0" text="Subtotal" />
                    <TableColumn fx:id="discountColumn" prefWidth="110.0" text="Discount" />
                    <TableColumn fx:id="totalColumn" prefWidth="110.0" text="Total" />
                    <TableColumn fx:id="cashColumn" prefWidth="110.0" text="Cash" />
                    <TableColumn fx:id="changeColumn" prefWidth="110.0" text="Change" />
                    <TableColumn fx:id="statusColumn" prefWidth="110.0" text="Status" />
                    <TableColumn fx:id="voidedByColumn" prefWidth="150.0" text="Voided By" />
                    <TableColumn fx:id="reasonColumn" prefWidth="220.0" text="Void Reason" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
