<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" styleClass="login-root" xmlns:fx="http://javafx.com/fxml/1" fx:controller="coffeeshopkiosk.controller.LoginController">
    <center>
        <VBox alignment="CENTER" maxWidth="420.0" spacing="16.0" styleClass="login-panel">
            <padding>
                <Insets bottom="36.0" left="36.0" right="36.0" top="36.0" />
            </padding>
            <Label styleClass="brand-title" text="BrewPoint POS-IMS" />
            <Label styleClass="muted-text" text="Coffee Shop Kiosk System" />
            <TextField fx:id="usernameField" promptText="Username" />
            <PasswordField fx:id="passwordField" onAction="#login" promptText="Password" />
            <Button maxWidth="Infinity" onAction="#login" styleClass="primary-button" text="Sign In" />
            <Label styleClass="hint-text" text="Demo accounts: admin/admin123 or cashier/cashier123" wrapText="true" />
        </VBox>
    </center>
</BorderPane>
