<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="coffeeshopkiosk.controller.DashboardController">
    <left>
        <VBox prefWidth="230.0" spacing="10.0" styleClass="sidebar">
            <padding>
                <Insets bottom="18.0" left="18.0" right="18.0" top="22.0" />
            </padding>
            <Label styleClass="sidebar-title" text="BrewPoint" />
            <Label fx:id="userLabel" styleClass="sidebar-user" text="Signed in" wrapText="true" />
            <Button maxWidth="Infinity" onAction="#showPOS" styleClass="nav-button" text="POS" />
            <Button fx:id="inventoryButton" maxWidth="Infinity" onAction="#showInventory" styleClass="nav-button" text="Inventory" />
            <Button fx:id="productsButton" maxWidth="Infinity" onAction="#showProducts" styleClass="nav-button" text="Products" />
            <Button fx:id="cashiersButton" maxWidth="Infinity" onAction="#showCashiers" styleClass="nav-button" text="Cashiers" />
            <Button fx:id="reportsButton" maxWidth="Infinity" onAction="#showReports" styleClass="nav-button" text="Reports" />
            <Button maxWidth="Infinity" onAction="#showHistory" styleClass="nav-button" text="Transaction History" />
            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" onAction="#logout" styleClass="danger-button" text="Logout" />
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentPane" styleClass="content-area" />
    </center>
</BorderPane>
