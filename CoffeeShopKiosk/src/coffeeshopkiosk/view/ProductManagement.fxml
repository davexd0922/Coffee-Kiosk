<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="coffeeshopkiosk.controller.ProductController">
    <padding>
        <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
    </padding>
    <top>
        <Label styleClass="screen-title" text="Product Management" />
    </top>
    <center>
        <HBox spacing="16.0">
            <VBox prefWidth="330.0" spacing="12.0" styleClass="form-panel">
                <Label styleClass="section-title" text="Categories" />
                <HBox spacing="8.0">
                    <TextField fx:id="newCategoryField" promptText="New category" HBox.hgrow="ALWAYS" />
                    <Button onAction="#addCategory" styleClass="primary-button" text="Add" />
                </HBox>
                <Label styleClass="section-title" text="Product Details" />
                <GridPane hgap="8.0" vgap="10.0">
                    <Label text="Name" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <Label text="Category" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <HBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <ComboBox fx:id="categoryComboBox" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
                        <Button onAction="#deleteSelectedCategory" styleClass="danger-button" text="Delete" />
                    </HBox>
                    <Label text="Price" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField fx:id="priceField" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <Label text="Stock" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <TextField fx:id="stockField" promptText="0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    <Label text="Image" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <TextField fx:id="imagePathField" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    <Label text="Status" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                    <ComboBox fx:id="statusComboBox" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                </GridPane>
                <ImageView fx:id="imagePreview" fitHeight="145.0" fitWidth="230.0" pickOnBounds="true" preserveRatio="true" styleClass="image-preview" />
                <Button onAction="#chooseImage" text="Choose Image" />
                <HBox spacing="8.0">
                    <Button onAction="#saveProduct" styleClass="primary-button" text="Save" />
                    <Button onAction="#deleteProduct" styleClass="danger-button" text="Delete" />
                    <Button onAction="#clearForm" text="Clear" />
                </HBox>
            </VBox>
            <TableView fx:id="productTable" HBox.hgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameColumn" prefWidth="180.0" text="Name" />
                    <TableColumn fx:id="categoryColumn" prefWidth="140.0" text="Category" />
                    <TableColumn fx:id="priceColumn" prefWidth="90.0" text="Price" />
                    <TableColumn fx:id="stockColumn" prefWidth="90.0" text="Stock" />
                    <TableColumn fx:id="statusColumn" prefWidth="130.0" text="Status" />
                </columns>
            </TableView>
        </HBox>
    </center>
</BorderPane>
