<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="coffeeshopkiosk.controller.InventoryController">
    <padding>
        <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
    </padding>
    <top>
        <VBox spacing="10.0">
            <Label styleClass="screen-title" text="Inventory Management" />
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label fx:id="lowStockLabel" styleClass="status-pill" text="0 low stock item(s)" />
                <TextField fx:id="restockQuantityField" promptText="Restock quantity" />
                <Button onAction="#restockSelected" styleClass="primary-button" text="Restock Selected" />
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="inventoryTable">
            <columns>
                <TableColumn fx:id="ingredientColumn" prefWidth="190.0" text="Ingredient" />
                <TableColumn fx:id="unitColumn" prefWidth="80.0" text="Unit" />
                <TableColumn fx:id="quantityColumn" prefWidth="130.0" text="On Hand" />
                <TableColumn fx:id="reorderColumn" prefWidth="130.0" text="Reorder Level" />
                <TableColumn fx:id="supplierColumn" prefWidth="180.0" text="Supplier" />
                <TableColumn fx:id="statusColumn" prefWidth="110.0" text="Status" />
            </columns>
        </TableView>
    </center>
</BorderPane>
